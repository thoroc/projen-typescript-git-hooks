{
  "tasks": {
    "biome": {
      "name": "biome",
      "description": "Runs Biome against the codebase",
      "steps": [
        {
          "exec": "biome check --no-errors-on-unmatched --write",
          "receiveArgs": true
        }
      ]
    },
    "build": {
      "name": "build",
      "description": "Full release build",
      "steps": [
        {
          "spawn": "default"
        },
        {
          "spawn": "pre-compile"
        },
        {
          "spawn": "compile"
        },
        {
          "spawn": "post-compile"
        },
        {
          "spawn": "test"
        },
        {
          "spawn": "package"
        }
      ]
    },
    "bump": {
      "name": "bump",
      "description": "Bumps version based on latest git tag and generates a changelog entry",
      "env": {
        "OUTFILE": "package.json",
        "CHANGELOG": "dist/changelog.md",
        "BUMPFILE": "dist/version.txt",
        "RELEASETAG": "dist/releasetag.txt",
        "RELEASE_TAG_PREFIX": "",
        "BUMP_PACKAGE": "commit-and-tag-version@^12"
      },
      "steps": [
        {
          "builtin": "release/bump-version"
        }
      ],
      "condition": "git log --oneline -1 | grep -qv \"chore(release):\""
    },
    "claude-code:install": {
      "name": "claude-code:install",
      "description": "Install Claude Code CLI",
      "steps": [
        {
          "exec": "command -v claude >/dev/null 2>&1 || npm install -g @anthropic-ai/claude-code",
          "name": "install-binary"
        }
      ]
    },
    "clobber": {
      "name": "clobber",
      "description": "hard resets to HEAD of origin and cleans the local repo",
      "env": {
        "BRANCH": "$(git branch --show-current)"
      },
      "steps": [
        {
          "exec": "git checkout -b scratch",
          "name": "save current HEAD in \"scratch\" branch"
        },
        {
          "exec": "git checkout $BRANCH"
        },
        {
          "exec": "git fetch origin",
          "name": "fetch latest changes from origin"
        },
        {
          "exec": "git reset --hard origin/$BRANCH",
          "name": "hard reset to origin commit"
        },
        {
          "exec": "git clean -fdx",
          "name": "clean all untracked files"
        },
        {
          "say": "ready to rock! (unpushed commits are under the \"scratch\" branch)"
        }
      ],
      "condition": "git diff --exit-code > /dev/null"
    },
    "codex:install": {
      "name": "codex:install",
      "description": "Install OpenAI Codex CLI",
      "steps": [
        {
          "exec": "command -v codex >/dev/null 2>&1 || npm install -g @openai/codex",
          "name": "install-binary"
        }
      ]
    },
    "commitizen": {
      "name": "commitizen",
      "description": "Commitizen's commit",
      "steps": [
        {
          "exec": "cz"
        }
      ]
    },
    "compat": {
      "name": "compat",
      "description": "Perform API compatibility check against latest version",
      "steps": [
        {
          "exec": "jsii-diff npm:$(node -p \"require('./package.json').name\") -k --ignore-file .compatignore || (echo \"\nUNEXPECTED BREAKING CHANGES: add keys such as 'removed:constructs.Node.of' to .compatignore to skip.\n\" && exit 1)"
        }
      ]
    },
    "compile": {
      "name": "compile",
      "description": "Only compile",
      "steps": [
        {
          "exec": "jsii --silence-warnings=reserved-word"
        }
      ]
    },
    "default": {
      "name": "default",
      "description": "Synthesize project files",
      "steps": [
        {
          "exec": "ts-node --project tsconfig.dev.json .projenrc.ts"
        }
      ]
    },
    "docgen": {
      "name": "docgen",
      "description": "Generate API.md from .jsii manifest",
      "steps": [
        {
          "exec": "jsii-docgen -o API.md"
        }
      ]
    },
    "eject": {
      "name": "eject",
      "description": "Remove projen from the project",
      "env": {
        "PROJEN_EJECTING": "true"
      },
      "steps": [
        {
          "spawn": "default"
        }
      ]
    },
    "gemini:install": {
      "name": "gemini:install",
      "description": "Install Gemini CLI",
      "steps": [
        {
          "exec": "command -v gemini >/dev/null 2>&1 || npm install -g @google/gemini-cli",
          "name": "install-binary"
        }
      ]
    },
    "harnesses:install": {
      "name": "harnesses:install",
      "description": "Install all enabled harness tools",
      "steps": [
        {
          "spawn": "claude-code:install"
        },
        {
          "spawn": "codex:install"
        },
        {
          "spawn": "opencode:install"
        },
        {
          "spawn": "gemini:install"
        },
        {
          "spawn": "vibe:install"
        }
      ]
    },
    "install": {
      "name": "install",
      "description": "Install project dependencies and update lockfile (non-frozen)",
      "steps": [
        {
          "exec": "bun install"
        }
      ]
    },
    "install:ci": {
      "name": "install:ci",
      "description": "Install project dependencies using frozen lockfile",
      "steps": [
        {
          "exec": "bun install --frozen-lockfile"
        }
      ]
    },
    "opencode:install": {
      "name": "opencode:install",
      "description": "Install OpenCode CLI",
      "steps": [
        {
          "exec": "command -v opencode >/dev/null 2>&1 || npm install -g opencode",
          "name": "install-binary"
        }
      ]
    },
    "package": {
      "name": "package",
      "description": "Creates the distribution package",
      "steps": [
        {
          "spawn": "package:js",
          "condition": "node -e \"if (!process.env.CI) process.exit(1)\""
        },
        {
          "spawn": "package-all",
          "condition": "node -e \"if (process.env.CI) process.exit(1)\""
        }
      ]
    },
    "package-all": {
      "name": "package-all",
      "description": "Packages artifacts for all target languages",
      "steps": [
        {
          "spawn": "package:js"
        }
      ]
    },
    "package:js": {
      "name": "package:js",
      "description": "Create js language bindings",
      "steps": [
        {
          "exec": "jsii-pacmak -v --target js"
        }
      ]
    },
    "post-compile": {
      "name": "post-compile",
      "description": "Runs after successful compilation",
      "steps": [
        {
          "spawn": "docgen"
        }
      ]
    },
    "post-upgrade": {
      "name": "post-upgrade",
      "description": "Runs after upgrading dependencies"
    },
    "pre-compile": {
      "name": "pre-compile",
      "description": "Prepare the project for compilation"
    },
    "release": {
      "name": "release",
      "description": "Prepare a release from \"main\" branch",
      "env": {
        "RELEASE": "true"
      },
      "steps": [
        {
          "exec": "rm -fr dist"
        },
        {
          "spawn": "bump"
        },
        {
          "spawn": "build"
        },
        {
          "spawn": "unbump"
        },
        {
          "exec": "git diff --ignore-space-at-eol --exit-code"
        }
      ]
    },
    "test": {
      "name": "test",
      "description": "Run tests",
      "steps": [
        {
          "exec": "vitest run",
          "receiveArgs": true
        }
      ]
    },
    "unbump": {
      "name": "unbump",
      "description": "Restores version to 0.0.0",
      "env": {
        "OUTFILE": "package.json",
        "CHANGELOG": "dist/changelog.md",
        "BUMPFILE": "dist/version.txt",
        "RELEASETAG": "dist/releasetag.txt",
        "RELEASE_TAG_PREFIX": "",
        "BUMP_PACKAGE": "commit-and-tag-version@^12"
      },
      "steps": [
        {
          "builtin": "release/reset-version"
        }
      ]
    },
    "upgrade": {
      "name": "upgrade",
      "description": "upgrade dependencies",
      "env": {
        "CI": "0"
      },
      "steps": [
        {
          "exec": "bunx npm-check-updates@18 --upgrade --target=minor --peer --no-deprecated --dep=dev,peer,prod,optional --filter=@commitlint/cli,@commitlint/config-conventional,@types/node,@vitest/coverage-v8,commitizen,cz-conventional-changelog,jsii-diff,jsii-pacmak,lefthook,projen,ts-node,typescript,vite-tsconfig-paths,vitest,change-case,type-fest,yaml"
        },
        {
          "exec": "bun install"
        },
        {
          "exec": "bun update @biomejs/biome @commitlint/cli @commitlint/config-conventional @types/node @vitest/coverage-v8 commit-and-tag-version commitizen constructs cz-conventional-changelog jsii-diff jsii-docgen jsii-pacmak jsii-rosetta jsii lefthook projen ts-node typescript vite-tsconfig-paths vitest change-case type-fest yaml"
        },
        {
          "exec": "bunx projen"
        },
        {
          "spawn": "post-upgrade"
        }
      ]
    },
    "vibe:install": {
      "name": "vibe:install",
      "description": "Install Mistral Vibe CLI",
      "steps": [
        {
          "exec": "command -v vibe >/dev/null 2>&1 || npm install -g @mistralai/vibe",
          "name": "install-binary"
        }
      ]
    },
    "watch": {
      "name": "watch",
      "description": "Watch & compile in the background",
      "steps": [
        {
          "exec": "jsii -w --silence-warnings=reserved-word"
        }
      ]
    }
  },
  "env": {
    "PATH": "$(bun --eval \"console.log(process.env.PATH)\")"
  },
  "//": "~~ Generated by projen. To modify, edit .projenrc.ts and run \"bunx projen\"."
}
